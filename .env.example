# Example environment variables for crypto-analytics-platform
# Copy this file to `.env` and fill in the values for your environment.
# DO NOT commit secrets or production credentials to source control.

# Application / server
APP_ENV=development            # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me           # random string used for app-level secrets
JWT_SECRET=change-me-jwt       # secret used to sign JWTs

# Database (Postgres example)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/crypto_db

# Cache / queue (Redis)
REDIS_URL=redis://localhost:6379/0

# External API keys (replace placeholders with real keys)
COINMARKETCAP_API_KEY=CMC-REPLACE_WITH_YOUR_KEY
BINANCE_API_KEY=                        # optional: exchange API key
BINANCE_API_SECRET=                     # optional: exchange API secret
ALPHAVANTAGE_API_KEY=                   # optional: historical price API

# CCXT (if using multiple exchanges via ccxt)
CCXT_EXCHANGE=binance
CCXT_API_KEY=
CCXT_API_SECRET=

# Observability
SENTRY_DSN=                             # e.g. https://<key>@sentry.io/<project>
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR | CRITICAL

# Email / notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=alerts@example.com
WEBHOOK_URL=                            # optional webhook to send alerts

# Runtime tuning
MAX_WORKERS=4
REQUEST_TIMEOUT=10                      # seconds for external HTTP calls

# Feature flags / environment-specific toggles
FEATURE_FLAG_EXPERIMENTAL=false

# Example usage comment:
# To query CoinGecko manually (no key required for many endpoints):
# https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=usd

GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp_credentials.json
BIGQUERY_TABLE_ID=crypto_analytics.btc_trades
# Preferred general project env name; used by BigQuery, Storage, Pub/Sub, etc.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Backwards compatibility (optional)
GCS_BUCKET_NAME=your-gcs-bucket-name